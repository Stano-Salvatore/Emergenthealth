# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get from: https://neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct URL bypasses PgBouncer (required for migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth / Auth.js v5 ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# Your app URL (use http://localhost:3000 for local dev)
AUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Calendar API, (optionally Google People API)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Actual Budget ───────────────────────────────────────────────────────────
# Your self-hosted Actual Budget server (must be publicly accessible from Vercel)
ACTUAL_SERVER_URL="https://actual.yourdomain.com"
ACTUAL_SERVER_PASSWORD="your-actual-server-password"
# Found in Actual Budget → Settings → Sync → Budget ID
ACTUAL_BUDGET_SYNC_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# ─── Smartwatch MCP Server ────────────────────────────────────────────────────
# Deployed as Next.js API routes at /api/mcp/sse and /api/mcp/messages
# Add https://YOUR-APP.vercel.app/api/mcp/sse as a Claude.ai web connector.

# Your login email — tells the MCP server whose health data to expose.
# Falls back to the first user in the DB if not set.
MCP_USER_EMAIL="your@email.com"

# Optional: protect the connector with a bearer token.
# If set, add "Authorization: Bearer <value>" in Claude.ai connector settings.
# Generate with: openssl rand -hex 32
MCP_READ_API_KEY=""

# Required to use the health_log write tool (pass as write_key argument).
# Generate with: openssl rand -hex 32
MCP_WRITE_API_KEY="your-mcp-write-key-here"

# ─── Standalone mcp-server/ (optional, for self-hosted deployment) ────────────
# HTTP port when running mcp-server in --http mode (default 3100)
# PORT=3100
