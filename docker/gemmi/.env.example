# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET=                            # openssl rand -base64 32
AUTH_URL=http://lenovo:3000             # or your Tailscale URL

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Tailscale ────────────────────────────────────────────────────────────────
# Your Tailscale machine hostname:port — allows Server Actions from that origin
TAILSCALE_HOST=lenovo.your-tailnet.ts.net:3000

# ─── Server monitoring ────────────────────────────────────────────────────────
# Leave SERVER_BRIDGE_URL empty — direct access is used when self-hosted
SERVER_BRIDGE_URL=
SERVER_BRIDGE_TOKEN=

# ─── Integrations (copy from your current Vercel env vars) ───────────────────
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
TOGGL_API_TOKEN=
# ... (add all others from Vercel dashboard)
