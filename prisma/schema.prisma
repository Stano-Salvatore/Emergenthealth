generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth.js v5 tables ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  digestDay     Int       @default(1)
  digestHour    Int       @default(8)

  accounts     Account[]
  sessions     Session[]
  healthLogs   HealthLog[]
  transactions Transaction[]
  habits       Habit[]
  reminders    Reminder[]
  chatMessages ChatMessage[]
  mcpApiKeys   McpApiKey[]
  fitToken     FitToken?
  ouraToken    OuraToken? @relation("OuraToken")
  ouraTags     OuraTag[]
  moodLogs     MoodLog[]
  tags         Tag[]
  checkIns     CheckIn[]
  savedPlaces  SavedPlace[]
  dailyNotes   DailyNote[]
  intakeLogs    IntakeLog[]
  focusSessions FocusSession[]
  driveImportLogs DriveImportLog[]
  books         Book[]
  morningCheckIns MorningCheckIn[]
  weatherLogs     WeatherLog[]
  userPreferences UserPreference[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Health ──────────────────────────────────────────────────────────────────

model HealthLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @db.Date

  sleepStart    DateTime?
  sleepEnd      DateTime?
  sleepDuration Int?
  deepSleep     Int?
  remSleep      Int?
  lightSleep    Int?

  steps          Int?
  caloriesBurned Int?
  activeMinutes  Int?

  workouts  Json?
  restingHR Int?
  weight    Float?

  // Oura extended metrics
  readinessScore       Int?
  hrv                  Float?
  spo2                 Float?
  skinTemp             Float?
  sleepEfficiency      Int?
  sleepLatency         Int?
  stressHigh           Int?
  totalCalories        Int?
  distanceKm           Float?
  // Oura v2 additional metrics
  breathingRate        Float?
  awakeTime            Int?
  timeInBed            Int?
  restlessPeriods      Int?
  activityScore        Int?
  recoveryHigh         Int?
  sedentaryTime        Int?
  breathingDisturbance Float?
  sleepScore           Int?

  syncedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Finances ────────────────────────────────────────────────────────────────

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  actualId      String?  @unique
  date          DateTime @db.Date
  amount        Int
  payee         String?
  category      String?
  categoryGroup String?
  accountName   String?
  notes         String?
  cleared       Boolean  @default(false)
  isTransfer    Boolean  @default(false)
  syncedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, category])
}

// ─── Drive Import Log ────────────────────────────────────────────────────────

model DriveImportLog {
  id         String   @id @default(cuid())
  userId     String
  fileId     String
  fileName   String
  importedAt DateTime @default(now())
  rowCount   Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
  @@index([userId])
}

// ─── Habits ──────────────────────────────────────────────────────────────────

model Habit {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String   @default("#6366f1")
  icon        String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  completions HabitCompletion[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HabitCompletion {
  id          String   @id @default(cuid())
  habitId     String
  userId      String
  date        DateTime @db.Date
  completedAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@index([userId, date])
}

// ─── Reminders ───────────────────────────────────────────────────────────────

model Reminder {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  priority    String    @default("normal")
  tags        String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@index([userId, isCompleted])
}

// ─── Mood ────────────────────────────────────────────────────────────────────

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  mood      Int      // 1–5: 1=awful, 2=bad, 3=ok, 4=good, 5=great
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String
  color  String @default("#6366f1")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

// ─── Check-ins ───────────────────────────────────────────────────────────────

model CheckIn {
  id           String    @id @default(cuid())
  userId       String
  place        String
  emoji        String    @default("📍")
  note         String?
  checkedAt    DateTime  @default(now())
  isAuto       Boolean   @default(false)
  savedPlaceId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, checkedAt])
}

// ─── Saved Places ─────────────────────────────────────────────────────────────

model SavedPlace {
  id        String   @id @default(cuid())
  userId    String
  name      String
  emoji     String   @default("📍")
  address   String?
  lat       Float
  lng       Float
  radiusM   Int      @default(100)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Daily Notes ─────────────────────────────────────────────────────────────

model DailyNote {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  content   String   @db.Text
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Intake Log (water / coffee / etc.) ─────────────────────────────────────

model IntakeLog {
  id       String   @id @default(cuid())
  userId   String
  type     String   // "water" | "coffee" | "tea" | "alcohol" | "other"
  amountMl Int
  note     String?
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

// ─── Reading Tracker ─────────────────────────────────────────────────────────

model Book {
  id          String    @id @default(cuid())
  userId      String
  title       String
  author      String?
  pages       Int?
  status      String    @default("reading") // "reading" | "done" | "wishlist"
  rating      Int?      // 1-5
  startedAt   DateTime?
  finishedAt  DateTime?
  notes       String?
  coverColor  String    @default("#6366f1")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ─── Focus Sessions (Pomodoro) ───────────────────────────────────────────────

model FocusSession {
  id          String   @id @default(cuid())
  userId      String
  durationMin Int
  type        String   @default("focus") // "focus" | "short_break" | "long_break"
  label       String?
  startedAt   DateTime
  endedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endedAt])
}

// ─── Chat ────────────────────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─── MCP / Google Fit ────────────────────────────────────────────────────────

model McpApiKey {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  name      String   @default("Default")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FitToken {
  id           String    @id @default(cuid())
  userId       String    @unique
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OuraTag {
  id        String   @id
  userId    String
  day       String
  timestamp DateTime
  tagName   String?
  text      String?
  tags      String[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, day])
}

model OuraToken {
  id           String    @id @default(cuid())
  userId       String    @unique
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation("OuraToken", fields: [userId], references: [id], onDelete: Cascade)
}

model MorningCheckIn {
  id          String   @id
  userId      String
  date        String
  energy      Int
  mood        Int
  intention   String?
  waterGoalMl Int      @default(2000)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
  @@index([userId])
}

model WeatherLog {
  id          String  @id
  userId      String
  date        String
  tempMaxC    Float?
  tempMinC    Float?
  precipMm    Float?
  uvIndex     Float?
  weatherCode Int?
  lat         Float?
  lon         Float?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
  @@index([userId])
}

model UserPreference {
  userId String
  key    String
  value  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([userId, key])
}

model TagAlias {
  userId      String
  tagTypeUuid String
  name        String
  @@id([userId, tagTypeUuid])
}
