{
  "name": "Emergenthealth",
  "short_name": "Health",
  "description": "Your personal health, fitness, and life dashboard",
  "id": "/?source=pwa",
  "start_url": "/dashboard?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#09090f",
  "theme_color": "#09090f",
  "orientation": "portrait-primary",
  "categories": ["health", "fitness", "productivity"],
  "icons": [
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "share_target": {
    "action": "/dashboard/journal",
    "method": "GET",
    "params": {
      "text": "share"
    }
  },
  "shortcuts": [
    {
      "name": "Morning Check-in",
      "short_name": "Check-in",
      "url": "/dashboard/checkin",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }],
      "description": "Log your morning energy and mood"
    },
    {
      "name": "Log Drinks",
      "short_name": "Drinks",
      "url": "/dashboard/intake",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }],
      "description": "Log water, coffee, beer"
    },
    {
      "name": "Log Mood",
      "short_name": "Mood",
      "url": "/dashboard/home",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }],
      "description": "Quick mood log"
    },
    {
      "name": "Finances",
      "short_name": "Finance",
      "url": "/dashboard/finances",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }],
      "description": "View spending and transactions"
    }
  ]
}
